# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/social_network_app
# Vercel: use Vercel Postgres or Neon connection string
DATABASE_URL="postgresql://socialnet:socialnet123@localhost:5432/social_network_app"

# Cron endpoint secret (required for Vercel Cron)
CRON_SECRET="change-this-to-a-random-string"

# AI provider API keys (server-side only — never exposed to browser)
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
HUGGINGFACE_API_KEY=""

# Ollama self-hosted config (optional)
OLLAMA_BASE_URL="http://localhost:11434"

# Public app URL (used by OpenRouter referrer header and cron calls)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
