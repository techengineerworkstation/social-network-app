# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/social_network_app
# Vercel: see Vercel Postgres dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/social_network_app"

# Optional: direct connection for migrations (some hosts require this)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/social_network_app"

# AI provider API keys (server-side only)
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
HUGGINGFACE_API_KEY=""

# Ollama self-hosted config (optional)
OLLAMA_BASE_URL="http://localhost:11434"

# Public app URL used by OpenRouter referrer header
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret to protect the scheduler endpoint
CRON_SECRET="change-this-to-a-random-string"
